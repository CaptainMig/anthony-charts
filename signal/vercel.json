{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/article/:id", "destination": "/api/og?id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/score.js": { "memory": 256, "maxDuration": 60 },
    "api/feed.js": { "memory": 256, "maxDuration": 30 },
    "api/extract.js": { "memory": 256, "maxDuration": 30 },
    "api/factcheck.js": { "memory": 256, "maxDuration": 15 },
    "api/og.js": { "memory": 256, "maxDuration": 10 },
    "api/aggregate.js": { "memory": 256, "maxDuration": 10 }
  }
}
